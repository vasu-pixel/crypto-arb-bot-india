# ── Binance Global API ───────────────────────────────────────
# https://www.binance.com/en/my/settings/api-management
# Paper mode: leave empty (public WebSocket data only, no auth needed)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── OKX API ──────────────────────────────────────────────────
# https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=

# ── Bybit API ────────────────────────────────────────────────
# https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ── Trading Mode ─────────────────────────────────────────────
# PAPER = simulated trades (default, safe for testing)
# LIVE  = real trades (requires funded API keys with trade permissions)
ARB_BOT_MODE=PAPER
