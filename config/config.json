{
  "mode": "paper",
  "exchanges": {
    "binance_us": {
      "api_key": "ENV:BINANCE_API_KEY",
      "secret_key": "ENV:BINANCE_SECRET_KEY",
      "rest_base_url": "https://api.binance.us",
      "ws_base_url": "wss://stream.binance.us:9443/ws"
    },
    "kraken": {
      "api_key": "ENV:KRAKEN_API_KEY",
      "secret_key": "ENV:KRAKEN_SECRET_KEY",
      "rest_base_url": "https://api.kraken.com",
      "ws_base_url": "wss://ws.kraken.com/v2"
    },
    "coinbase": {
      "api_key": "ENV:COINBASE_API_KEY",
      "secret_key": "ENV:COINBASE_SECRET_KEY",
      "rest_base_url": "https://api.coinbase.com",
      "ws_base_url": "wss://advanced-trade-ws.coinbase.com"
    }
  },
  "strategy": {
    "min_net_spread_bps": 3.0,
    "min_trade_size_usd": 50.0,
    "max_trade_size_usd": 5000.0,
    "max_open_positions": 3,
    "order_timeout_ms": 5000,
    "partial_fill_wait_ms": 2000
  },
  "inventory": {
    "drift_threshold_pct": 20.0,
    "balance_refresh_interval_s": 30
  },
  "server": {
    "ws_port": 9002,
    "heartbeat_interval_s": 5
  },
  "persistence": {
    "trades_file": "data/trades.json",
    "paper_trades_file": "data/paper_trades.json"
  },
  "logging": {
    "level": "info",
    "file": "logs/arb_bot.log"
  },
  "data_recording": {
    "enabled": false,
    "directory": "data/historical"
  },
  "paper_trading": {
    "initial_balances": {
      "BTC": 0.6,
      "ETH": 10.0,
      "USD": 30000.0,
      "SOL": 100.0,
      "XRP": 5000.0,
      "ADA": 10000.0,
      "DOGE": 50000.0,
      "DOT": 500.0,
      "LINK": 500.0,
      "AVAX": 200.0
    }
  }
}
