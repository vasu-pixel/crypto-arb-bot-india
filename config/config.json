{
  "mode": "paper",
  "exchanges": {
    "binance": {
      "api_key": "ENV:BINANCE_API_KEY",
      "secret_key": "ENV:BINANCE_SECRET_KEY",
      "rest_base_url": "https://api.binance.com",
      "ws_base_url": "wss://stream.binance.com:9443/ws"
    },
    "okx": {
      "api_key": "ENV:OKX_API_KEY",
      "secret_key": "ENV:OKX_SECRET_KEY",
      "rest_base_url": "https://www.okx.com",
      "ws_base_url": "wss://ws.okx.com:8443/ws/v5/public"
    },
    "bybit": {
      "api_key": "ENV:BYBIT_API_KEY",
      "secret_key": "ENV:BYBIT_SECRET_KEY",
      "rest_base_url": "https://api.bybit.com",
      "ws_base_url": "wss://stream.bybit.com/v5/public/spot"
    },
    "mexc": {
      "api_key": "ENV:MEXC_API_KEY",
      "secret_key": "ENV:MEXC_SECRET_KEY",
      "rest_base_url": "https://api.mexc.com",
      "ws_base_url": "wss://wbs.mexc.com/ws"
    },
    "gateio": {
      "api_key": "ENV:GATEIO_API_KEY",
      "secret_key": "ENV:GATEIO_SECRET_KEY",
      "rest_base_url": "https://api.gateio.ws",
      "ws_base_url": "wss://api.gateio.ws/ws/v4/"
    }
  },
  "strategy": {
    "min_net_spread_bps": 2.0,
    "min_trade_size_usd": 10.0,
    "max_trade_size_usd": 100.0,
    "max_open_positions": 3,
    "order_timeout_ms": 5000,
    "partial_fill_wait_ms": 2000
  },
  "inventory": {
    "drift_threshold_pct": 20.0,
    "balance_refresh_interval_s": 30
  },
  "server": {
    "ws_port": 9003,
    "heartbeat_interval_s": 5
  },
  "persistence": {
    "trades_file": "data/trades.json",
    "paper_trades_file": "data/paper_trades.json"
  },
  "logging": {
    "level": "info",
    "file": "logs/arb_bot.log"
  },
  "data_recording": {
    "enabled": false,
    "directory": "data/historical"
  },
  "paper_trading": {
    "initial_balances": {
      "USDT": 700.0,
      "BTC": 0.002,
      "ETH": 0.05,
      "SOL": 1.0
    }
  }
}
